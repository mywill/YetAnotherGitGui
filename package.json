{
  "name": "yagg",
  "version": "1.13.3",
  "description": "A Git GUI application built with Tauri",
  "packageManager": "pnpm@10.33.0",
  "author": "kd",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mywill/YetAnotherGitGui.git"
  },
  "bugs": {
    "url": "https://github.com/mywill/YetAnotherGitGui/issues"
  },
  "homepage": "https://github.com/mywill/YetAnotherGitGui#readme",
  "keywords": [
    "git",
    "gui",
    "tauri",
    "react",
    "typescript"
  ],
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "playwright install chromium",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\"",
    "lint:rust": "cd src-tauri && cargo clippy -- -D warnings && cargo fmt --check",
    "format:rust": "cd src-tauri && cargo fmt",
    "fallow": "fallow",
    "fallow:audit": "pnpm test:coverage --run && fallow audit --base origin/main --coverage coverage/coverage-final.json --production-dead-code --production-health --production-dupes",
    "fallow:health": "pnpm test:coverage --run && fallow health --coverage coverage/coverage-final.json --production",
    "fallow:watch": "fallow watch",
    "fallow:ci": "mkdir -p .fallow && pnpm test:coverage --run && (fallow audit --base origin/main --format json --coverage coverage/coverage-final.json --production-dead-code --production-health --production-dupes > .fallow/audit.json || true)",
    "check": "bash scripts/check.sh"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm fallow:audit || true"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.1.1",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@tabler/icons-react": "^3.44.0",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-cli": "^2.0.0",
    "@tauri-apps/plugin-clipboard-manager": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-process": "^2.0.0",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-window": "^2.2.7",
    "zustand": "^5.0.14"
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/changelog",
      [
        "@semantic-release/exec",
        {
          "prepareCmd": "node scripts/update-versions.mjs ${nextRelease.version}"
        }
      ],
      [
        "@semantic-release/git",
        {
          "assets": [
            "CHANGELOG.md",
            "package.json",
            "src-tauri/Cargo.toml",
            "src-tauri/tauri.conf.json"
          ],
          "message": "chore(release): ${nextRelease.version}"
        }
      ],
      "@semantic-release/github"
    ]
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@tailwindcss/vite": "^4.3.1",
    "@tauri-apps/cli": "^2.11.2",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "^4.1.9",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "fallow": "2.74.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "semantic-release": "^25.0.5",
    "simple-git-hooks": "2.13.1",
    "tailwindcss": "4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^8.0.1",
    "vitest": "^4.1.9"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "fallow",
      "simple-git-hooks"
    ]
  }
}
